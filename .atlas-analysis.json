  "publicApiSurface": [
    "GET /api/years - List available years",
    "GET /api/statistics?year={year} - Get statistics for a year",
    "GET /api/category?year={year}&category={category} - Get category details",
    "GET /api/companies - List all participating schools",
    "GET /api/participants?name={name}&company={company} - Search participants"
